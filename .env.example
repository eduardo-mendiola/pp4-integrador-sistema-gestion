# ===========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ===========================================
# Copy this file to .env and replace the values
# between {braces} with your actual credentials.
# NEVER commit the real .env file to the repo.
# ===========================================

PORT=4000
NODE_ENV=development

# Local MongoDB connection
# MONGO_URI_ATLAS=mongodb://localhost:27017/db

# MongoDB Atlas connection
MONGO_URI_ATLAS=mongodb+srv://{user}:{pass}.mongodb.net/{db_name}

# Authentication Secrets
JWT_SECRET={your_super_secret_jwt_key_change_this_in_production}
SESSION_SECRET={your_super_secret_session_key_change_this_in_production}

# Admin credentials for testing purposes
ADMIN_EMAIL={user}
ADMIN_PASS={pass}

# Cookie for testing purposes (replace with actual value after login)
CONNECT_SID_VALUE={cookie}