{
  "name": "tecnova_api_restful",
  "version": "1.0.0",
  "description": "Aplicación para gestión de jugueterias",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:client": "npm --prefix client run build",
    "start:prod": "npm run build:client && node server.js",
    "test:db": "node test-db-connection.js",
    "repair:users-persons": "node scripts-local/repair-users-persons.js"
  },
  "author": "Eduardo Mendiola",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.6",
    "express": "5.1.0",
    "express-session": "^1.18.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "method-override": "^3.0.0",
    "mongoose": "^8.18.2",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "dotenv": "17.2.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "3.1.10",
    "supertest": "^7.0.0"
  }
}
